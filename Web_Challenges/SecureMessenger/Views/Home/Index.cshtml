@{
    Layout = null;
}
<!doctype html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Secure Messenger</title>
    <link rel="stylesheet" href="/site.css" />
</head>
<body>
    <div class="app-container">

        <div class="header">
            <h1>Secure Messenger</h1>
        </div>

        <div class="card">
            <form method="post" action="/Preview/Preview">

                <textarea name="template" placeholder="Type your message here..." spellcheck="false"></textarea>

                <button type="submit">Send</button>
            </form>
        </div>

    </div>
</body>
</html>
