<%- include('partials/header') %>
</head>
<body>
    <nav>
        <div class="container nav-inner">
            <a href="/" class="logo">Chroma<span class="accent">Leak</span></a>
            <div class="nav-links">
                <span class="nav-user"><%= user.username %></span>
                <a href="/dashboard">My Notes</a>
                <a href="/create">New Note</a>
                <a href="/report">Report</a>
                <a href="/logout">Logout</a>
            </div>
        </div>
    </nav>

    <main class="container">
        <!-- CSRF Protection Token -->
        <form id="csrf-protection" aria-hidden="true">
            <input type="text" name="csrf_token" value="<%= csrfToken %>" readonly tabindex="-1"
                   style="position:absolute;left:-9999px;width:1px;height:1px;overflow:hidden;border:0;padding:0;">
        </form>

        <div class="form-container wide">
            <h2>Create Note</h2>
            <% if (error) { %>
                <div class="alert alert-error"><%= error %></div>
            <% } %>
            <form method="POST" action="/create">
                <div class="form-group">
                    <label for="title">Title</label>
                    <input type="text" id="title" name="title" required maxlength="100"
                           placeholder="My Awesome Note">
                </div>
                <div class="form-group">
                    <label for="content">Content</label>
                    <textarea id="content" name="content" rows="6" required maxlength="5000"
                              placeholder="Write your note here..."></textarea>
                </div>
                <div class="form-group">
                    <label for="css">Custom CSS Theme <span class="optional">(optional)</span></label>
                    <textarea id="css" name="css" rows="10" maxlength="5000"
                              placeholder="/* Customize the look of your note */&#10;.note-content {&#10;    color: #ff6b6b;&#10;    font-family: serif;&#10;}"></textarea>
                    <small>
                        Add custom CSS to style your note. Some CSS features are restricted for security.
                        Max 5000 characters.
                    </small>
                </div>
                <button type="submit" class="btn btn-primary btn-full">Create Note</button>
            </form>
        </div>
    </main>

<%- include('partials/footer') %>
